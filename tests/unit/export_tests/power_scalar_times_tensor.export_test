x^(2) * A{a1;i1}

=================================================
Plain Text
=================================================
Declare index i_1
Declare index a_1

Declare variable x

Declare tensor A[a_1, i_1]
Declare tensor I[a_1, i_1]

Create I[a_1, i_1] and initialize to zero
Load x
Load A[a_1, i_1]
Compute I[a_1, i_1] += x^2 A[a_1, i_1]
Unload A[a_1, i_1]
Unload x
Persist I[a_1, i_1]

=================================================
Julia (TensorOperations)
=================================================
I_vo = zeros(Float64, nv, nocc)
x = deserialize("x.jlbin")
A_vo = deserialize("A_vo.jlbin")
@tensor I_vo[ a_1, i_1 ] += x^2 * A_vo[ a_1, i_1 ]
A_vo = nothing
x = nothing
return I_vo

=================================================
Python (einsum)
=================================================
import numpy as np
import os

I_vo = np.zeros((nvirt, nocc), order='F')
x = np.load('x.npy')
A_vo = np.load('A_vo.npy')
I_vo += x**2 * np.einsum('ai->ai', A_vo, optimize=True)
del A_vo
del x
np.save('I_vo.npy', I_vo)

