A{a1;i1;u1} A{a2;i2;u1}

=================================================
Plain Text
batch_indices: i_2
=================================================
Declare index i_1
Declare index i_2
Declare index a_1
Declare index a_2
Declare index u_1

Declare tensor A[a_1, i_1, u_1]
Declare tensor I[i_1, i_2, a_1, a_2]

Start batching over i_2
Create I[i_1, i_2, a_1, a_2] and initialize to zero
Load A[a_1, i_1, u_1]
Load A[a_2, i_2, u_1]
Compute I[i_1, i_2, a_1, a_2] += A[a_1, i_1, u_1] A[a_2, i_2, u_1]
Unload A[a_2, i_2, u_1]
Unload A[a_1, i_1, u_1]
Persist I[i_1, i_2, a_1, a_2]
End batching

=================================================
ITF
batch_indices: i_1,i_2
# Note that in this test tensors A[j...] and A[k...] are
# no longer the same tensor block as batching causes j and
# k to become distinct batched index spaces.
=================================================
---- decl
index-space: j, Closed, c
index-space: k, Closed, c
index-space: b, External, e
index-space: c, External, e
index-space: v, Active, a

tensor: A:eca[bjv], A:eca
tensor: I:eecc[bcjk], I:eecc


---- code("unnamed")
for [j, k]:
	alloc I:eecc[bcjk]
	load A:eca[bjv]
	load A:eca[ckv]
	.I:eecc[bcjk] += A:eca[bjv] A:eca[ckv]
	drop A:eca[ckv]
	drop A:eca[bjv]
	store I:eecc[bcjk]


---- end

