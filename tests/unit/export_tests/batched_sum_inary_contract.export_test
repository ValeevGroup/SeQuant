Declare index u_1

Declare tensor A[a_1, i_1, u_1]
Declare tensor B[a_2, i_2, u_1]
Declare tensor I[i_1, i_2, a_1, a_2]

Start batching over i_1, i_2
Create I[i_1, i_2, a_1, a_2] and initialize to zero
Load A[a_1, i_1, u_1]
Load B[a_2, i_2, u_1]
Compute I[i_1, i_2, a_1, a_2] += A[a_1, i_1, u_1] B[a_2, i_2, u_1]
Unload B[a_2, i_2, u_1]
Unload A[a_1, i_1, u_1]
Load B[a_1, i_1, u_1]
Load B[a_2, i_2, u_1]
Compute I[i_1, i_2, a_1, a_2] += B[a_1, i_1, u_1] B[a_2, i_2, u_1]
Unload B[a_2, i_2, u_1]
Unload B[a_1, i_1, u_1]
Persist I[i_1, i_2, a_1, a_2]
End batching

