tensor: A:eca[bjv], A:eca
tensor: B:eca[ckv], B:eca
tensor: I:eecc[bcjk], I:eecc


---- code("unnamed")
for [j, k]:
	alloc I:eecc[bcjk]
	load A:eca[bjv]
	load B:eca[ckv]
	.I:eecc[bcjk] += A:eca[bjv] B:eca[ckv]
	drop B:eca[ckv]
	drop A:eca[bjv]
	load B:eca[bjv]
	load B:eca[ckv]
	.I:eecc[bcjk] += B:eca[bjv] B:eca[ckv]
	drop B:eca[ckv]
	drop B:eca[bjv]
	store I:eecc[bcjk]


---- end

