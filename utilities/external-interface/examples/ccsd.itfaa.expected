tensor: T2:eecc[abji], T2:eecc
tensor: f:ee[ab], f:ee
tensor: f:ec[ai], f:ec
tensor: f:cc[ji], f:cc


---- code("Residual")
alloc CSE1:ec[bi]
load K:eecc[abij]
load T1:ec[aj]
.CSE1:ec[bi] += K:eecc[abij] T1:ec[aj]
drop T1:ec[aj]
drop K:eecc[abij]
store CSE1:ec[bi]

alloc CSE2:ec[bj]
load K:eecc[abij]
load T1:ec[ai]
.CSE2:ec[bj] += K:eecc[abij] T1:ec[ai]
