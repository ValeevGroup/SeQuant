drop K:eecc[abij]
store CSE2:ec[bj]

alloc ECC[]
load f:ec[ai]
load T1:ec[ai]
.ECC[] += 2 * f:ec[ai] T1:ec[ai]
drop T1:ec[ai]
drop f:ec[ai]
load K:eecc[abij]
load T2:eecc[abji]
.ECC[] += -1 * K:eecc[abij] T2:eecc[abji]
drop T2:eecc[abji]
drop K:eecc[abij]
load CSE1:ec[bi]
load T1:ec[bi]
.ECC[] += -1 * CSE1:ec[bi] T1:ec[bi]
drop T1:ec[bi]
drop CSE1:ec[bi]
load K:eecc[abij]
load T2:eecc[abij]
.ECC[] += 2 * K:eecc[abij] T2:eecc[abij]
drop T2:eecc[abij]
drop K:eecc[abij]
load CSE2:ec[bj]
load T1:ec[bj]
.ECC[] += 2 * CSE2:ec[bj] T1:ec[bj]
drop T1:ec[bj]
drop CSE2:ec[bj]
store ECC[]

alloc CSE3:eccc[bkji]
