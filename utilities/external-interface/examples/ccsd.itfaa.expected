---- decl
index-space: a, External, e
index-space: b, External, e
index-space: c, External, e
index-space: d, External, e
index-space: i, Closed, c
index-space: j, Closed, c
index-space: k, Closed, c
index-space: l, Closed, c

tensor: ECC[], ECC

tensor: CSE1:ec[bi], !Create{type:disk}
tensor: CSE1:eccc[dkli], !Create{type:disk}
tensor: CSE2:ec[bj], !Create{type:disk}
tensor: CSE2:eecc[ackj], !Create{type:disk}
