R1{u1;i1} =
  + f{u1;i1}:A-H-S
  - Ym1{u1;u2} f{u2;i1}:A-H-S
  - Ym1{u3;u2} g{u1,u2;u3,i1}:A-H-S
  + 1/2 Ym2{u1,u4;u2,u3} g{u2,u3;u4,i1}:A-H-S
  - g{i2;i1}:A-H-S T1{u1;i2}
  + g{i2;i1}:A-H-S Ym1{u1;u2} T1{u2;i2}
  + f{u1;u2}:A-H-S T1{u2;i1}
  - Ym1{u1;u2} f{u2;u3}:A-H-S T1{u3;i1}
  + Ym1{u4;u2} g{u1,u2;u3,u4}:A-H-S T1{u3;i1}
  - 1/2 Ym2{u1,u5;u2,u3} g{u2,u3;u4,u5}:A-H-S T1{u4;i1}